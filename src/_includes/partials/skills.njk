<section id="skills" class="py-20 sm:py-24" aria-labelledby="skills-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="skills-heading" class="text-2xl sm:text-3xl font-bold text-white mb-4 text-center reveal">
      Skills & Expertise
    </h2>
    <p class="text-gray-400 text-center mb-10 max-w-3xl mx-auto reveal leading-relaxed">
      A toolkit forged in high-pressure environments where speed, accuracy, and trust are non-negotiable.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {% for group in skills %}
        <article class="reveal group bg-surface-800 rounded-xl p-6 border border-surface-700/50 transition-all duration-300 hover:border-brand-500/50 hover:shadow-[0_12px_28px_rgba(0,0,0,0.35)]" aria-label="{{ group.category }}">
          <div class="flex items-center justify-between mb-5">
            <h3 class="text-xs font-bold text-brand-400 uppercase tracking-widest">
              {{ group.category }}
            </h3>
            <div class="w-2 h-2 rounded-full bg-brand-500"></div>
          </div>

          {% if group.narrative %}
            <p class="text-sm text-gray-300 leading-relaxed mb-4 min-h-[3.25rem]">
              {{ group.narrative }}
            </p>
          {% endif %}

          <ul class="flex flex-wrap gap-2" role="list" aria-label="{{ group.category }} capabilities">
            {% for skill in group.items %}
              <li class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs sm:text-sm font-medium bg-surface-700/85 text-gray-200 border border-surface-600/70 hover:border-brand-500/40 hover:text-white transition-colors">
                <span aria-hidden="true">{{ skill.icon }}</span>
                <span>{{ skill.name }}</span>
              </li>
            {% endfor %}
          </ul>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
