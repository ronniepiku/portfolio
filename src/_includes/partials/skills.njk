<section id="skills" class="py-20 sm:py-24" aria-labelledby="skills-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="skills-heading" class="text-2xl sm:text-3xl font-bold text-white mb-12 text-center">
      Skills & Expertise
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for group in skills %}
        <div class="bg-surface-800 rounded-xl p-6 border border-surface-700/50 hover:border-brand-500/30 transition-colors">
          <h3 class="text-sm font-semibold text-brand-400 uppercase tracking-wider mb-4">
            {{ group.category }}
          </h3>
          <ul class="space-y-3" role="list">
            {% for skill in group.items %}
              <li class="flex items-center gap-3 text-gray-300">
                <span class="text-lg" aria-hidden="true">{{ skill.icon }}</span>
                <span class="text-sm font-medium">{{ skill.name }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
