<section id="skills" class="py-20 sm:py-24" aria-labelledby="skills-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="skills-heading" class="text-2xl sm:text-3xl font-bold text-white mb-4 text-center reveal">
      Skills & Expertise
    </h2>
    <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto reveal">
      A comprehensive toolkit built through hands-on experience in Formula 1 and machine learning projects
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {% for group in skills %}
        <div class="reveal group bg-surface-800 rounded-xl p-6 border border-surface-700/50 hover-lift hover:border-brand-500/50 transition-all duration-300 cursor-pointer">
          <div class="flex items-center justify-between mb-5">
            <h3 class="text-xs font-bold text-brand-400 uppercase tracking-widest">
              {{ group.category }}
            </h3>
            <div class="w-2 h-2 rounded-full bg-brand-500 group-hover:animate-pulse"></div>
          </div>
          <ul class="space-y-3.5" role="list">
            {% for skill in group.items %}
              <li class="group/item">
                <div class="flex items-center gap-3 text-gray-300 group-hover/item:text-white transition-colors">
                  <span class="text-xl group-hover/item:scale-125 transition-transform duration-300" aria-hidden="true">{{ skill.icon }}</span>
                  <span class="text-sm font-medium">{{ skill.name }}</span>
                </div>
                <div class="skill-bar mt-1.5" style="--skill-level: {{ skill.level or 85 }}%"></div>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
