<section id="projects" class="py-20 sm:py-24 bg-surface-800/30" aria-labelledby="projects-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="projects-heading" class="text-2xl sm:text-3xl font-bold text-white mb-4 text-center reveal">
      Featured Projects
    </h2>
    <p class="text-gray-400 text-center mb-12 max-w-3xl mx-auto reveal leading-relaxed">
      Stories of building practical ML products and data systems, with visual proof and hands-on paths to explore each project.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for project in projects %}
        <article class="reveal group bg-surface-800 rounded-xl border border-surface-700/50 overflow-hidden flex flex-col relative transition-all duration-300 hover:border-brand-500/40 hover:shadow-[0_12px_28px_rgba(0,0,0,0.35)]">
          <div class="relative h-48 bg-gradient-to-br from-surface-700 to-surface-900 overflow-hidden">
            {% if project.media and project.media.src %}
              <img
                src="{{ project.media.src | url }}"
                alt="{{ project.media.alt or project.title }}"
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              >
            {% else %}
              <div class="absolute inset-0 bg-brand-500/5"></div>
            {% endif %}

            <div class="absolute inset-0 bg-gradient-to-t from-surface-900 via-surface-900/20 to-transparent"></div>

            {% if project.status %}
              <p class="absolute top-3 left-3 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] rounded-full bg-surface-900/80 text-brand-200 border border-brand-500/30">
                {{ project.status }}
              </p>
            {% endif %}
          </div>

          <div class="p-6 flex-1 flex flex-col relative z-10">
            <h3 class="text-lg font-bold text-white mb-3 group-hover:text-brand-400 transition-colors">
              <a href="{{ project.links.caseStudy | url }}" class="hover:text-brand-400">
                {{ project.title }}
              </a>
            </h3>

            {% if project.subtitle %}
              <p class="text-sm text-brand-300 mb-3">{{ project.subtitle }}</p>
            {% endif %}

            <p class="text-sm text-gray-300 leading-relaxed mb-4">{{ project.storyHook or project.description }}</p>

            {% if project.impact %}
              <p class="text-sm text-gray-200 border-l-2 border-brand-500/50 pl-3 mb-4 leading-relaxed">
                <span class="text-brand-300 font-medium">Impact:</span> {{ project.impact }}
              </p>
            {% endif %}

            {% if project.confidentiality %}
              <p class="text-xs text-gray-400 mb-4 uppercase tracking-[0.14em]">{{ project.confidentiality }}</p>
            {% endif %}

            <div class="flex flex-wrap gap-1.5 mb-4">
              {% for tag in project.tags %}
                <span class="px-2.5 py-1 text-xs font-medium bg-surface-700 text-brand-300 rounded-full group-hover:bg-brand-900/30 group-hover:text-brand-200 transition-all duration-300">{{ tag }}</span>
              {% endfor %}
            </div>
          </div>

          <div class="px-6 pb-6 pt-2 flex flex-wrap gap-3 border-t border-surface-700/50 relative z-10">
            <a href="{{ project.links.caseStudy | url }}" class="text-sm text-brand-400 hover:text-brand-300 font-semibold transition-colors group/link flex items-center gap-1">
              Story
              <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>

            {% if project.links.demo %}
              <a href="{{ project.links.demo }}" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-300 hover:text-white transition-colors font-medium flex items-center gap-1" aria-label="Open demo for {{ project.title }}">
                Demo
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            {% endif %}

            {% if project.links.github %}
              <a href="{{ project.links.github }}" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-white transition-colors font-medium flex items-center gap-1" aria-label="View {{ project.title }} on GitHub">
                GitHub
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            {% endif %}

            {% if project.links.download %}
              <a href="{{ project.links.download }}" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-300 hover:text-white transition-colors font-medium flex items-center gap-1" aria-label="Download {{ project.title }}">
                Download
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V4"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
