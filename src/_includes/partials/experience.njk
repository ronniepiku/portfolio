<section id="experience" class="py-20 sm:py-24 bg-surface-800/30" aria-labelledby="experience-heading">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="experience-heading" class="text-2xl sm:text-3xl font-bold text-white mb-4 text-center reveal">
      Work Experience
    </h2>
    <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto reveal">
      Building high-performance data systems and machine learning solutions in motorsport
    </p>
    <div class="relative">
      <!-- Animated timeline line -->
      <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gradient-to-b from-brand-500 via-brand-600 to-surface-600 hidden sm:block" aria-hidden="true"></div>

      <div class="space-y-12">
        {% for job in experience %}
          <div class="reveal relative sm:pl-12 group">
            <!-- Animated timeline dot -->
            <div class="absolute left-2.5 top-1.5 w-3 h-3 bg-brand-500 rounded-full ring-4 ring-surface-900 group-hover:ring-brand-500/20 transition-all duration-300 hidden sm:block" style="animation: pulse-glow 2s ease-in-out infinite;" aria-hidden="true"></div>

            <div class="bg-surface-800 rounded-xl p-6 border border-surface-700/50 hover-lift hover:border-brand-500/30">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-3 gap-2">
                <h3 class="text-xl font-bold text-white group-hover:text-brand-400 transition-colors">{{ job.role }}</h3>
                <span class="text-sm text-gray-400 font-mono bg-surface-700/50 px-3 py-1 rounded-full">{{ job.period }}</span>
              </div>
              <p class="text-brand-400 font-semibold text-base mb-4 flex items-center gap-2">
                <span>{{ job.company }}</span>
                <span class="text-xs text-gray-500">•</span>
                <span class="text-sm text-gray-400 font-normal">{{ job.location or "Remote" }}</span>
              </p>
              <ul class="space-y-2.5" role="list">
                {% for item in job.highlights %}
                  <li class="text-sm text-gray-300 leading-relaxed pl-5 relative before:content-['▸'] before:absolute before:left-0 before:text-brand-500 before:font-bold hover:text-white transition-colors">
                    {{ item }}
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
