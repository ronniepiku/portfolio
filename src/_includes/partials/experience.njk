<section id="experience" class="py-20 sm:py-24 bg-surface-800/30" aria-labelledby="experience-heading">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="experience-heading" class="text-2xl sm:text-3xl font-bold text-white mb-12 text-center">
      Work Experience
    </h2>
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 top-0 bottom-0 w-px bg-surface-600 hidden sm:block" aria-hidden="true"></div>

      <div class="space-y-12">
        {% for job in experience %}
          <div class="relative sm:pl-12">
            <!-- Timeline dot -->
            <div class="absolute left-2.5 top-1.5 w-3 h-3 bg-brand-500 rounded-full ring-4 ring-surface-900 hidden sm:block" aria-hidden="true"></div>

            <div class="bg-surface-800 rounded-xl p-6 border border-surface-700/50">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3">
                <h3 class="text-lg font-semibold text-white">{{ job.role }}</h3>
                <span class="text-sm text-gray-400 font-mono mt-1 sm:mt-0">{{ job.period }}</span>
              </div>
              <p class="text-brand-400 font-medium text-sm mb-4">{{ job.company }}</p>
              <ul class="space-y-2" role="list">
                {% for item in job.highlights %}
                  <li class="text-sm text-gray-300 leading-relaxed pl-4 relative before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-brand-500/60 before:rounded-full">
                    {{ item }}
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
