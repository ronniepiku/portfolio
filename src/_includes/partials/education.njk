<section id="education" class="py-20 sm:py-24" aria-labelledby="education-heading">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="education-heading" class="text-2xl sm:text-3xl font-bold text-white mb-12 text-center">
      Education
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {% for edu in education %}
        <div class="bg-surface-800 rounded-xl p-6 border border-surface-700/50">
          <h3 class="text-lg font-semibold text-white mb-1">{{ edu.degree }}</h3>
          <p class="text-brand-400 font-medium text-sm mb-2">{{ edu.institution }}</p>
          <p class="text-gray-400 text-sm font-mono mb-2">{{ edu.period }}</p>
          <p class="text-gray-300 text-sm font-medium">{{ edu.result }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
