<section id="education" class="py-20 sm:py-24" aria-labelledby="education-heading">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="education-heading" class="text-2xl sm:text-3xl font-bold text-white mb-4 text-center reveal">
      Education
    </h2>
    <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto reveal">
      Academic foundation in data science and engineering
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {% for edu in education %}
        <div class="reveal bg-surface-800 rounded-xl p-6 border border-surface-700/50 hover-lift hover:border-brand-500/30 group">
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-lg font-bold text-white group-hover:text-brand-400 transition-colors">{{ edu.degree }}</h3>
            <span class="text-2xl" aria-hidden="true">🎓</span>
          </div>
          <p class="text-brand-400 font-semibold text-base mb-2">{{ edu.institution }}</p>
          <p class="text-gray-400 text-sm font-mono mb-3 bg-surface-700/50 inline-block px-2 py-1 rounded">{{ edu.period }}</p>
          <p class="text-gray-200 text-sm font-semibold">{{ edu.result }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
