---
layout: layouts/base.njk
---
<article class="max-w-4xl mx-auto px-4 py-16 sm:px-6 lg:px-8">
  <a href="{{ '/#projects' | url }}" class="inline-flex items-center text-brand-400 hover:text-brand-300 mb-8 transition-colors">
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Projects
  </a>

  <header class="mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">{{ title }}</h1>
    {% if subtitle %}
      <p class="text-lg text-brand-300 mb-4 leading-relaxed">{{ subtitle }}</p>
    {% endif %}

    {% if storyHook %}
      <p class="text-gray-300 leading-relaxed mb-6">{{ storyHook }}</p>
    {% endif %}

    {% if impactSummary %}
      <p class="text-sm text-gray-200 border-l-2 border-brand-500/50 pl-3 mb-6 leading-relaxed">
        <span class="text-brand-300 font-medium">Impact:</span> {{ impactSummary }}
      </p>
    {% endif %}

    <div class="flex flex-wrap gap-2 mb-6">
      {% for tag in tags %}
        <span class="px-3 py-1 text-xs font-medium bg-surface-700 text-brand-300 rounded-full">{{ tag }}</span>
      {% endfor %}
    </div>

    <div class="flex flex-wrap gap-3">
      {% if github %}
        <a href="{{ github }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-2 bg-surface-600 hover:bg-surface-700 text-white rounded-lg transition-colors text-sm font-medium">
          View Repository ↗
        </a>
      {% endif %}

      {% if demoUrl %}
        <a href="{{ demoUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-lg transition-colors text-sm font-medium">
          {{ demoLabel or "Open Demo" }} ↗
        </a>
      {% endif %}

      {% if downloadUrl %}
        <a href="{{ downloadUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-lg transition-colors text-sm font-medium">
          {{ downloadLabel or "Download" }} ↗
        </a>
      {% endif %}
    </div>
  </header>

  {% if heroImage or heroVideo %}
    <section class="mb-10 rounded-2xl border border-surface-700/60 overflow-hidden bg-surface-800">
      {% if heroVideo %}
        <video controls preload="metadata" class="w-full h-auto" poster="{{ heroImage | url }}">
          <source src="{{ heroVideo | url }}" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      {% else %}
        <img src="{{ heroImage | url }}" alt="{{ heroAlt or title }}" class="w-full h-auto object-cover" loading="lazy">
      {% endif %}
    </section>
  {% endif %}

  {% if demoEmbed %}
    <section class="mb-10 rounded-2xl border border-surface-700/60 overflow-hidden bg-surface-800 p-4 sm:p-5">
      <h2 class="text-lg sm:text-xl font-semibold text-white mb-3">Interactive Walkthrough</h2>
      <iframe src="{{ demoEmbed }}" title="Interactive walkthrough for {{ title }}" loading="lazy" class="w-full h-[420px] rounded-lg border border-surface-700" allowfullscreen></iframe>
    </section>
  {% endif %}

  <div class="prose prose-invert prose-brand max-w-none">
    {{ content | safe }}
  </div>

  {% if confidentialityNote %}
    <p class="mt-10 text-sm text-gray-400 leading-relaxed border-t border-surface-700 pt-5">{{ confidentialityNote }}</p>
  {% endif %}
</article>
