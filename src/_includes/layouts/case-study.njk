---
layout: layouts/base.njk
---
<article class="max-w-4xl mx-auto px-4 py-16 sm:px-6 lg:px-8">
  <a href="{{ '/#projects' | url }}" class="inline-flex items-center text-brand-400 hover:text-brand-300 mb-8 transition-colors">
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Projects
  </a>

  <header class="mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">{{ title }}</h1>
    <div class="flex flex-wrap gap-2 mb-6">
      {% for tag in tags %}
        <span class="px-3 py-1 text-xs font-medium bg-surface-700 text-brand-300 rounded-full">{{ tag }}</span>
      {% endfor %}
    </div>
    {% if colab %}
      <a href="{{ colab }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-lg transition-colors text-sm font-medium">
        Open in Google Colab ↗
      </a>
    {% endif %}
    {% if binder %}
      <a href="{{ binder }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-2 bg-surface-600 hover:bg-surface-700 text-white rounded-lg transition-colors text-sm font-medium ml-2">
        Launch on Binder ↗
      </a>
    {% endif %}
  </header>

  <div class="prose prose-invert prose-brand max-w-none">
    {{ content | safe }}
  </div>
</article>
