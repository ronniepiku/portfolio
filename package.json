{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Professional portfolio — performance data analyst & ML engineer",
  "scripts": {
    "dev": "npm-run-all build:css --parallel dev:*",
    "dev:eleventy": "npx @11ty/eleventy --serve --watch",
    "dev:css": "npx tailwindcss -i src/css/main.css -o _site/css/main.css --watch",
    "build": "npx @11ty/eleventy && npx tailwindcss -i src/css/main.css -o _site/css/main.css --minify",
    "build:css": "npx tailwindcss -i src/css/main.css -o _site/css/main.css --minify",
    "format": "prettier --write \"**/*.{js,json,md,njk,css}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,njk,css}\"",
    "test": "npx playwright test",
    "test:install": "npx playwright install --with-deps chromium",
    "clean": "node -e \"require('fs').rmSync('_site', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@playwright/test": "^1.45.0",
    "autoprefixer": "^10.4.19",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}